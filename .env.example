# T-map API (https://openapi.sk.com 에서 발급)
TMAP_API_KEY=your_tmap_api_key_here

# 카카오 API (https://developers.kakao.com 에서 발급)
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
KAKAO_ACCESS_TOKEN=your_kakao_access_token_here

# 기상청 API (https://www.data.go.kr 에서 발급)
WEATHER_API_KEY=your_weather_api_key_here

# ntfy.sh 채널명 (본인이 원하는 이름으로 설정, 예: wife-commute-1234)
NTFY_TOPIC=wife-commute-1234

# 서버 포트
PORT=3000

# 출발지/도착지 좌표 (기본값 설정됨)
ORIGIN_ADDRESS=부산광역시 부산진구 동평로 176
DEST_ADDRESS=경남 김해시 경원로 73번길 15

# 알림 시각 (cron 형식, 기본 오전 7:30)
CRON_SCHEDULE=30 7 * * 1-5
