# T-map API (https://openapi.sk.com 에서 발급)
TMAP_APP_KEY=your_tmap_app_key_here

# 카카오 API (https://developers.kakao.com 에서 발급)
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
KAKAO_ACCESS_TOKEN=your_kakao_access_token_here
KAKAO_REFRESH_TOKEN=your_kakao_refresh_token_here

# 텔레그램 알림
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ntfy.sh 채널명 (본인이 원하는 이름으로 설정, 예: wife-commute-1234)
NTFY_TOPIC=wife-commute-1234

# iCal 일정 URL (선택)
ICAL_URL=

# 서버 포트
PORT=3000

# 출발지/도착지 좌표 (기본값 설정됨)
ORIGIN_ADDRESS=부산광역시 부산진구 동평로 176
DEST_ADDRESS=경남 김해시 경원로 73번길 15

# 알림 시각 (cron 형식, 기본 오전 7:10)
CRON_SCHEDULE=10 7 * * 1-5

# 서버 내장 cron 사용 여부 (GitHub Actions와 함께 쓰면 중복 발송될 수 있음)
ENABLE_LOCAL_CRON=false

# 외부 API 타임아웃(ms)
TMAP_TIMEOUT_MS=10000
WEATHER_TIMEOUT_MS=10000
CALENDAR_TIMEOUT_MS=10000
KAKAO_TIMEOUT_MS=10000
TELEGRAM_TIMEOUT_MS=10000
NOTIFICATION_TIMEOUT_MS=10000
